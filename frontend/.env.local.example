# Copy to frontend/.env.local for local development.

# Backend API base URL (no trailing slash). Default dev: Express on port 3000.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Run the frontend on a different port to avoid clashing with the API:
#   npm run dev -- -p 3001
# Set FRONTEND_URL=http://localhost:3001 in backend/.env for CORS.
